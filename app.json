{
  "expo": {
    "name": "Tajyire",
    "slug": "tajyire",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tajyire-logo.png",
    "scheme": "reactdir",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SeamlessNav uses your location to navigate you to Tajyire and provide proximity alerts.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SeamlessNav uses your location even in background to alert you when you are near Tajyire.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      },
      "bundleIdentifier": "com.seamlessnav.app"
    },
    "android": {
      "package": "com.seamlessnav.app",
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/tajyire-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/tajyire-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SeamlessNav uses your location to navigate you to Tajyire.",
          "locationWhenInUsePermission": "Allow SeamlessNav to use your location for outdoor navigation.",
          "locationAlwaysPermission": "Allow SeamlessNav to use your location even in background to detect when you approach the mall.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "foregroundService": {
            "notificationTitle": "SeamlessNav",
            "notificationBody": "Tracking your approach to Tajyire",
            "notificationColor": "#0066CC"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#0066CC"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
